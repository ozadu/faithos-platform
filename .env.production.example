# FaithOS production-like environment template
# Copy to your secret manager or deployment environment. Do not commit real values.
NODE_ENV=production
ENABLE_DEMO_SEED=false

DATABASE_URL=postgresql://user:password@db.example.org:5432/faithos
REDIS_URL=redis://redis.example.org:6379

JWT_SECRET=replace-with-strong-production-secret-at-least-32-characters
JWT_REFRESH_SECRET=replace-with-different-strong-production-secret-at-least-32-characters
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

SMTP_HOST=smtp.example.org
SMTP_PORT=587
SMTP_USER=replace-with-smtp-user
SMTP_PASSWORD=replace-with-smtp-password
SMTP_FROM=FaithOS <no-reply@example.org>
EMAIL_NOTIFICATIONS_ENABLED=true

APP_URL=https://faithos.example.org
API_URL=https://api.faithos.example.org
WEB_URL=https://faithos.example.org
NEXT_PUBLIC_API_URL=https://api.faithos.example.org
NEXT_PUBLIC_ENABLE_DEMO_CREDENTIALS=false

UPLOAD_DIR=/var/lib/faithos/uploads
ATTACHMENT_STORAGE_DIR=/var/lib/faithos/uploads
MAX_UPLOAD_SIZE=10485760
DEFAULT_TIMEZONE=Africa/Lagos
DEFAULT_CURRENCY=NGN
PILOT_BACKUP_DIR=/var/backups/faithos

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum DocumentStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  FORWARDED
  RETURNED
  APPROVED
  REJECTED
  ARCHIVED
}

enum DocumentPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum DocumentConfidentiality {
  PUBLIC
  INTERNAL
  CONFIDENTIAL
  RESTRICTED
}

enum DocumentRouteAction {
  SUBMITTED
  FORWARDED
  RETURNED
  RECEIVED
}

enum DocumentTimelineAction {
  CREATED
  EDITED
  SUBMITTED
  FORWARDED
  RETURNED
  RECEIVED
  ARCHIVED
}

enum WorkflowInstanceStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
  REJECTED
}

enum WorkflowTaskStatus {
  PENDING
  RECEIVED
  APPROVED
  REJECTED
  RETURNED
  FORWARDED
  COMPLETED
  CANCELLED
  OVERDUE
}

enum WorkflowHistoryAction {
  STARTED
  APPROVED
  REJECTED
  RETURNED
  FORWARDED
  RECEIVED
  COMPLETED
  CANCELLED
  DELEGATED
  REMINDER
  ESCALATED
}

enum WorkflowConditionOperator {
  LT
  LTE
  GT
  GTE
  EQ
  NEQ
}

enum WorkflowNotificationType {
  APPROVAL_REQUIRED
  RETURNED
  REJECTED
  FORWARDED
  COMPLETED
  ESCALATED
  REMINDER
  DOCUMENT_SUBMITTED
  DOCUMENT_FORWARDED
  DOCUMENT_RETURNED
  DOCUMENT_ARCHIVED
  WORKFLOW_ASSIGNED
  WORKFLOW_APPROVED
  WORKFLOW_REJECTED
  WORKFLOW_RETURNED
  WORKFLOW_COMPLETED
  WORKFLOW_OVERDUE
  DELEGATION_ASSIGNED
}

model Organization {
  id              String             @id @default(uuid()) @db.Uuid
  name            String
  slug            String             @unique
  email           String
  phone           String?
  address         String?
  country         String
  timezone        String             @default("UTC")
  shortName       String?
  website         String?
  logoUrl         String?
  defaultCurrency String             @default("NGN")
  status          OrganizationStatus @default(ACTIVE)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  departments         Department[]
  users               User[]
  passwordResetTokens PasswordResetToken[]
  roles               Role[]
  sessions            Session[]
  auditLogs           AuditLog[]
  documents           Document[]
  attachments         DocumentAttachment[]
  routes              DocumentRoute[]
  timeline            DocumentTimelineEvent[]
  workflows           Workflow[]
  workflowAssignments WorkflowAssignment[]
  workflowInstances   WorkflowInstance[]
  workflowTasks       WorkflowTask[]
  workflowHistory     WorkflowHistoryEvent[]
  delegations         WorkflowDelegation[]
  notifications       WorkflowNotification[]
  documentTypes       DocumentType[]
  systemSettings      SystemSetting[]
  pilotFeedback       PilotFeedback[]
  pilotIssues         PilotIssue[]
  onboardingItems     AdminOnboardingItem[]
}

model Department {
  id                 String    @id @default(uuid()) @db.Uuid
  organizationId     String    @db.Uuid
  name               String
  code               String?
  description        String?
  parentDepartmentId String?   @db.Uuid
  departmentHeadId   String?   @db.Uuid
  active             Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  organization          Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parentDepartment      Department?             @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id], onDelete: SetNull)
  childDepartments      Department[]            @relation("DepartmentHierarchy")
  departmentHead        User?                   @relation("DepartmentHead", fields: [departmentHeadId], references: [id], onDelete: SetNull)
  members               User[]                  @relation("DepartmentMembers")
  sentDocuments         Document[]              @relation("DocumentSenderDepartment")
  currentDocuments      Document[]              @relation("DocumentCurrentDepartment")
  routesFrom            DocumentRoute[]         @relation("RouteFromDepartment")
  routesTo              DocumentRoute[]         @relation("RouteToDepartment")
  timelineFrom          DocumentTimelineEvent[] @relation("TimelineFromDepartment")
  timelineTo            DocumentTimelineEvent[] @relation("TimelineToDepartment")
  workflowSteps         WorkflowStep[]
  assignedWorkflowTasks WorkflowTask[]
  workflowHistory       WorkflowHistoryEvent[]
  workflowNotifications WorkflowNotification[]

  @@unique([organizationId, name])
  @@unique([organizationId, code])
  @@index([organizationId, deletedAt])
  @@index([organizationId, active])
}

model User {
  id             String     @id @default(uuid()) @db.Uuid
  organizationId String     @db.Uuid
  departmentId   String?    @db.Uuid
  roleId         String?    @db.Uuid
  firstName      String
  lastName       String
  email          String     @unique
  phone          String?
  passwordHash   String
  jobTitle       String?
  status         UserStatus @default(ACTIVE)
  lastLoginAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  deletedAt      DateTime?

  organization           Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  department             Department?             @relation("DepartmentMembers", fields: [departmentId], references: [id], onDelete: SetNull)
  role                   Role?                   @relation(fields: [roleId], references: [id], onDelete: SetNull)
  headedDepartments      Department[]            @relation("DepartmentHead")
  sessions               Session[]
  passwordResetTokens    PasswordResetToken[]
  auditLogs              AuditLog[]
  ownedDocuments         Document[]              @relation("DocumentOwner")
  createdDocuments       Document[]              @relation("DocumentCreator")
  updatedDocuments       Document[]              @relation("DocumentUpdater")
  uploadedAttachments    DocumentAttachment[]
  routedDocuments        DocumentRoute[]
  timelineEvents         DocumentTimelineEvent[]
  startedWorkflows       WorkflowInstance[]
  assignedWorkflowTasks  WorkflowTask[]          @relation("WorkflowTaskAssignee")
  delegatedWorkflowTasks WorkflowTask[]          @relation("WorkflowTaskDelegatedFrom")
  workflowHistory        WorkflowHistoryEvent[]
  delegationsFrom        WorkflowDelegation[]    @relation("DelegationFromUser")
  delegationsTo          WorkflowDelegation[]    @relation("DelegationToUser")
  workflowNotifications  WorkflowNotification[]
  submittedFeedback      PilotFeedback[]         @relation("PilotFeedbackSubmitter")
  createdPilotIssues     PilotIssue[]            @relation("PilotIssueCreator")
  onboardingItems        AdminOnboardingItem[]

  @@index([organizationId, deletedAt])
  @@index([organizationId, departmentId])
  @@index([organizationId, roleId])
}

model Role {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String?  @db.Uuid
  name           String
  description    String?
  isSystem       Boolean  @default(false)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization    Organization?    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users           User[]
  rolePermissions RolePermission[]
  workflowSteps   WorkflowStep[]
  workflowTasks   WorkflowTask[]

  @@unique([organizationId, name])
  @@index([organizationId, isSystem])
  @@index([organizationId, active])
}

model Permission {
  id          String  @id @default(uuid()) @db.Uuid
  code        String  @unique
  displayName String
  module      String
  description String?

  rolePermissions RolePermission[]
}

model RolePermission {
  roleId       String @db.Uuid
  permissionId String @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model Session {
  id               String    @id @default(uuid()) @db.Uuid
  organizationId   String    @db.Uuid
  userId           String    @db.Uuid
  refreshTokenHash String
  userAgent        String?
  ipAddress        String?
  revokedAt        DateTime?
  expiresAt        DateTime
  createdAt        DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId])
  @@index([userId, revokedAt, expiresAt])
}

model PasswordResetToken {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @db.Uuid
  userId         String    @db.Uuid
  tokenHash      String
  expiresAt      DateTime
  usedAt         DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId, usedAt])
  @@index([expiresAt])
}

model AuditLog {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String?  @db.Uuid
  userId         String?  @db.Uuid
  action         String
  entityType     String
  entityId       String?  @db.Uuid
  oldValues      Json?
  newValues      Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
  @@index([entityType, entityId])
}

model Document {
  id                  String                  @id @default(uuid()) @db.Uuid
  organizationId      String                  @db.Uuid
  referenceNumber     String                  @unique
  title               String
  subject             String
  body                String
  category            String
  priority            DocumentPriority        @default(NORMAL)
  confidentiality     DocumentConfidentiality @default(INTERNAL)
  senderDepartmentId  String                  @db.Uuid
  currentDepartmentId String                  @db.Uuid
  ownerUserId         String                  @db.Uuid
  status              DocumentStatus          @default(DRAFT)
  createdBy           String                  @db.Uuid
  updatedBy           String                  @db.Uuid
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  organization          Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  senderDepartment      Department              @relation("DocumentSenderDepartment", fields: [senderDepartmentId], references: [id], onDelete: Restrict)
  currentDepartment     Department              @relation("DocumentCurrentDepartment", fields: [currentDepartmentId], references: [id], onDelete: Restrict)
  owner                 User                    @relation("DocumentOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  creator               User                    @relation("DocumentCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  updater               User                    @relation("DocumentUpdater", fields: [updatedBy], references: [id], onDelete: Restrict)
  attachments           DocumentAttachment[]
  routes                DocumentRoute[]
  timeline              DocumentTimelineEvent[]
  workflowInstances     WorkflowInstance[]
  workflowTasks         WorkflowTask[]
  workflowHistory       WorkflowHistoryEvent[]
  workflowNotifications WorkflowNotification[]

  @@index([organizationId, status, createdAt])
  @@index([organizationId, currentDepartmentId, status])
  @@index([organizationId, senderDepartmentId])
  @@index([organizationId, ownerUserId, status])
  @@index([organizationId, referenceNumber])
}

model DocumentAttachment {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  documentId     String   @db.Uuid
  fileName       String
  storedFileName String
  storagePath    String
  mimeType       String
  sizeBytes      Int
  uploadedBy     String   @db.Uuid
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  document     Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  uploader     User         @relation(fields: [uploadedBy], references: [id], onDelete: Restrict)

  @@index([organizationId, documentId])
  @@index([uploadedBy, createdAt])
}

model DocumentRoute {
  id               String              @id @default(uuid()) @db.Uuid
  organizationId   String              @db.Uuid
  documentId       String              @db.Uuid
  fromDepartmentId String              @db.Uuid
  toDepartmentId   String              @db.Uuid
  routedBy         String              @db.Uuid
  action           DocumentRouteAction
  note             String?
  isRead           Boolean             @default(false)
  receivedAt       DateTime?
  createdAt        DateTime            @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  document       Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  fromDepartment Department   @relation("RouteFromDepartment", fields: [fromDepartmentId], references: [id], onDelete: Restrict)
  toDepartment   Department   @relation("RouteToDepartment", fields: [toDepartmentId], references: [id], onDelete: Restrict)
  routedByUser   User         @relation(fields: [routedBy], references: [id], onDelete: Restrict)

  @@index([organizationId, documentId, createdAt])
  @@index([organizationId, toDepartmentId, isRead])
  @@index([organizationId, fromDepartmentId, createdAt])
}

model DocumentTimelineEvent {
  id               String                 @id @default(uuid()) @db.Uuid
  organizationId   String                 @db.Uuid
  documentId       String                 @db.Uuid
  action           DocumentTimelineAction
  actorUserId      String                 @db.Uuid
  fromDepartmentId String?                @db.Uuid
  toDepartmentId   String?                @db.Uuid
  note             String?
  metadata         Json?
  createdAt        DateTime               @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  document       Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  actor          User         @relation(fields: [actorUserId], references: [id], onDelete: Restrict)
  fromDepartment Department?  @relation("TimelineFromDepartment", fields: [fromDepartmentId], references: [id], onDelete: SetNull)
  toDepartment   Department?  @relation("TimelineToDepartment", fields: [toDepartmentId], references: [id], onDelete: SetNull)

  @@index([organizationId, documentId, createdAt])
  @@index([actorUserId, createdAt])
}

model Workflow {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  name           String
  description    String?
  active         Boolean  @default(true)
  version        Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  versions     WorkflowVersion[]
  steps        WorkflowStep[]
  assignments  WorkflowAssignment[]
  instances    WorkflowInstance[]

  @@unique([organizationId, name])
  @@index([organizationId, active])
}

model WorkflowVersion {
  id          String   @id @default(uuid()) @db.Uuid
  workflowId  String   @db.Uuid
  version     Int
  active      Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())

  workflow  Workflow           @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  steps     WorkflowStep[]
  instances WorkflowInstance[]

  @@unique([workflowId, version])
  @@index([workflowId, active])
}

model WorkflowStep {
  id                String                     @id @default(uuid()) @db.Uuid
  workflowId        String                     @db.Uuid
  workflowVersionId String?                    @db.Uuid
  sequence          Int
  departmentId      String                     @db.Uuid
  roleId            String?                    @db.Uuid
  approvalRequired  Boolean                    @default(true)
  canReturn         Boolean                    @default(true)
  canForward        Boolean                    @default(false)
  dueDays           Int                        @default(2)
  escalationDays    Int                        @default(1)
  notifyEmail       Boolean                    @default(false)
  notifyInApp       Boolean                    @default(true)
  conditionField    String?
  conditionOperator WorkflowConditionOperator?
  conditionValue    String?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  workflow        Workflow               @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  workflowVersion WorkflowVersion?       @relation(fields: [workflowVersionId], references: [id], onDelete: Cascade)
  department      Department             @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  role            Role?                  @relation(fields: [roleId], references: [id], onDelete: SetNull)
  instances       WorkflowInstance[]     @relation("CurrentWorkflowStep")
  tasks           WorkflowTask[]
  previousHistory WorkflowHistoryEvent[] @relation("PreviousWorkflowStep")
  nextHistory     WorkflowHistoryEvent[] @relation("NextWorkflowStep")

  @@unique([workflowId, workflowVersionId, sequence])
  @@index([workflowId, sequence])
  @@index([departmentId])
  @@index([roleId])
}

model WorkflowAssignment {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  documentType   String
  workflowId     String   @db.Uuid
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workflow     Workflow     @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([organizationId, documentType])
  @@index([organizationId, active])
  @@index([workflowId])
}

model WorkflowInstance {
  id                String                 @id @default(uuid()) @db.Uuid
  organizationId    String                 @db.Uuid
  documentId        String                 @db.Uuid
  workflowId        String                 @db.Uuid
  workflowVersionId String?                @db.Uuid
  currentStepId     String?                @db.Uuid
  status            WorkflowInstanceStatus @default(IN_PROGRESS)
  metadata          Json?
  startedBy         String                 @db.Uuid
  completedAt       DateTime?
  cancelledAt       DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  organization    Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  document        Document               @relation(fields: [documentId], references: [id], onDelete: Cascade)
  workflow        Workflow               @relation(fields: [workflowId], references: [id], onDelete: Restrict)
  workflowVersion WorkflowVersion?       @relation(fields: [workflowVersionId], references: [id], onDelete: SetNull)
  currentStep     WorkflowStep?          @relation("CurrentWorkflowStep", fields: [currentStepId], references: [id], onDelete: SetNull)
  starter         User                   @relation(fields: [startedBy], references: [id], onDelete: Restrict)
  tasks           WorkflowTask[]
  history         WorkflowHistoryEvent[]
  notifications   WorkflowNotification[]

  @@index([organizationId, status, createdAt])
  @@index([organizationId, documentId])
  @@index([workflowId, status])
}

model WorkflowTask {
  id                   String             @id @default(uuid()) @db.Uuid
  organizationId       String             @db.Uuid
  workflowInstanceId   String             @db.Uuid
  documentId           String             @db.Uuid
  stepId               String             @db.Uuid
  assignedDepartmentId String             @db.Uuid
  assignedRoleId       String?            @db.Uuid
  assignedUserId       String?            @db.Uuid
  delegatedFromUserId  String?            @db.Uuid
  status               WorkflowTaskStatus @default(PENDING)
  dueAt                DateTime
  reminderAt           DateTime?
  escalatedAt          DateTime?
  receivedAt           DateTime?
  completedAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  organization       Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workflowInstance   WorkflowInstance @relation(fields: [workflowInstanceId], references: [id], onDelete: Cascade)
  document           Document         @relation(fields: [documentId], references: [id], onDelete: Cascade)
  step               WorkflowStep     @relation(fields: [stepId], references: [id], onDelete: Restrict)
  assignedDepartment Department       @relation(fields: [assignedDepartmentId], references: [id], onDelete: Restrict)
  assignedRole       Role?            @relation(fields: [assignedRoleId], references: [id], onDelete: SetNull)
  assignedUser       User?            @relation("WorkflowTaskAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  delegatedFromUser  User?            @relation("WorkflowTaskDelegatedFrom", fields: [delegatedFromUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, status, dueAt])
  @@index([organizationId, assignedDepartmentId, status])
  @@index([organizationId, assignedUserId, status])
  @@index([workflowInstanceId, createdAt])
}

model WorkflowHistoryEvent {
  id                 String                @id @default(uuid()) @db.Uuid
  organizationId     String                @db.Uuid
  workflowInstanceId String                @db.Uuid
  documentId         String                @db.Uuid
  actorUserId        String                @db.Uuid
  actorDepartmentId  String?               @db.Uuid
  action             WorkflowHistoryAction
  comments           String?
  previousStepId     String?               @db.Uuid
  nextStepId         String?               @db.Uuid
  metadata           Json?
  createdAt          DateTime              @default(now())

  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workflowInstance WorkflowInstance @relation(fields: [workflowInstanceId], references: [id], onDelete: Cascade)
  document         Document         @relation(fields: [documentId], references: [id], onDelete: Cascade)
  actor            User             @relation(fields: [actorUserId], references: [id], onDelete: Restrict)
  actorDepartment  Department?      @relation(fields: [actorDepartmentId], references: [id], onDelete: SetNull)
  previousStep     WorkflowStep?    @relation("PreviousWorkflowStep", fields: [previousStepId], references: [id], onDelete: SetNull)
  nextStep         WorkflowStep?    @relation("NextWorkflowStep", fields: [nextStepId], references: [id], onDelete: SetNull)

  @@index([organizationId, documentId, createdAt])
  @@index([workflowInstanceId, createdAt])
  @@index([actorUserId, createdAt])
}

model WorkflowDelegation {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  fromUserId     String   @db.Uuid
  toUserId       String   @db.Uuid
  startsAt       DateTime
  endsAt         DateTime
  active         Boolean  @default(true)
  reason         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fromUser     User         @relation("DelegationFromUser", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser       User         @relation("DelegationToUser", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([organizationId, fromUserId, active])
  @@index([organizationId, toUserId, active])
}

model WorkflowNotification {
  id                 String                   @id @default(uuid()) @db.Uuid
  organizationId     String                   @db.Uuid
  userId             String?                  @db.Uuid
  departmentId       String?                  @db.Uuid
  documentId         String?                  @db.Uuid
  workflowInstanceId String?                  @db.Uuid
  type               WorkflowNotificationType
  title              String
  message            String
  readAt             DateTime?
  createdAt          DateTime                 @default(now())

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user             User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  department       Department?       @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  document         Document?         @relation(fields: [documentId], references: [id], onDelete: Cascade)
  workflowInstance WorkflowInstance? @relation(fields: [workflowInstanceId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId, readAt])
  @@index([organizationId, departmentId, readAt])
  @@index([workflowInstanceId, createdAt])
}

model DocumentType {
  id                     String                  @id @default(uuid()) @db.Uuid
  organizationId         String                  @db.Uuid
  name                   String
  description            String?
  referencePrefix        String                  @default("DOC")
  defaultConfidentiality DocumentConfidentiality @default(INTERNAL)
  defaultPriority        DocumentPriority        @default(NORMAL)
  active                 Boolean                 @default(true)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([organizationId, active])
}

model SystemSetting {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  key            String
  value          Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, key])
  @@index([organizationId])
}

model PilotFeedback {
  id                String   @id @default(uuid()) @db.Uuid
  organizationId    String   @db.Uuid
  submittedByUserId String?  @db.Uuid
  name              String
  email             String
  roleOrDepartment  String
  type              String
  affectedArea      String
  priority          String
  message           String
  screenshotUrl     String?
  status            String   @default("NEW")
  adminNote         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  submitter    User?        @relation("PilotFeedbackSubmitter", fields: [submittedByUserId], references: [id], onDelete: SetNull)
  issues       PilotIssue[]

  @@index([organizationId, status, priority])
  @@index([organizationId, type, createdAt])
}

model PilotIssue {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @db.Uuid
  feedbackId      String?  @db.Uuid
  title           String
  description     String
  source          String
  severity        String
  status          String   @default("OPEN")
  assignedOwner   String?
  relatedArea     String?
  createdByUserId String?  @db.Uuid
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  feedback     PilotFeedback? @relation(fields: [feedbackId], references: [id], onDelete: SetNull)
  creator      User?          @relation("PilotIssueCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, status, severity])
  @@index([organizationId, source, createdAt])
}

model AdminOnboardingItem {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  userId         String   @db.Uuid
  key            String
  completedAt    DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId, key])
  @@index([organizationId, key])
}

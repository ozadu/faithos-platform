# FaithOS local/pilot environment template
# Never commit real secrets. Use strong JWT secrets, HTTPS in production,
# production SMTP outside Mailpit, and a documented backup policy.
NODE_ENV=development

# Local service credentials and connection strings
POSTGRES_DB=faithos
POSTGRES_USER=faithos
POSTGRES_PASSWORD=faithos
DATABASE_URL=postgresql://faithos:faithos@localhost:5432/faithos
REDIS_URL=redis://localhost:6379

# Replace these development values before using a shared environment
JWT_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
REFRESH_TOKEN_SECRET=replace-with-a-different-long-random-secret
JWT_EXPIRES_IN=15m
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# Mailpit SMTP and web UI
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=FaithOS <no-reply@faithos.local>
MAILPIT_UI_PORT=8025
ATTACHMENT_STORAGE_DIR=./storage/attachments
UPLOAD_DIR=./storage/attachments
MAX_UPLOAD_SIZE=10485760

# Application endpoints
API_PORT=3001
WEB_PORT=3000
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
WEB_URL=http://localhost:3000
FAITHOS_RELEASE=v0.8.0-pilot
DEFAULT_TIMEZONE=Africa/Lagos
DEFAULT_CURRENCY=NGN

# Pilot operations helpers
PILOT_BACKUP_DIR=./backups
PILOT_HEALTH_API_URL=http://localhost:3001/health
PILOT_HEALTH_SWAGGER_URL=http://localhost:3001/api/docs
PILOT_HEALTH_WEB_URL=http://localhost:3000

# Local service credentials and connection strings
POSTGRES_DB=faithos
POSTGRES_USER=faithos
POSTGRES_PASSWORD=faithos
DATABASE_URL=postgresql://faithos:faithos@localhost:5432/faithos
REDIS_URL=redis://localhost:6379

# Replace these development values before using a shared environment
JWT_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# Mailpit SMTP and web UI
SMTP_HOST=localhost
SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# Application endpoints
API_PORT=3001
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001
